            <!-- First space that doesn't have margin for the top!-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="@drawable/roundedfull"
                android:backgroundTint="#faf7f7"
                android:orientation="horizontal"
                android:padding="15dp">

                <LinearLayout
                    android:id="@+id/leftside"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1.5"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="100dp"
                        android:layout_height="20dp"
                        android:background="@drawable/roundedfull"
                        android:backgroundTint="#dddded"
                        android:fontFamily="@font/inter"
                        android:padding="2dp"
                        android:text="Game Difficulty"
                        android:textAlignment="center"
                        android:textSize="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/inter"
                        android:padding="1dp"
                        android:text="Game Title"
                        android:textAlignment="textStart"
                        android:textFontWeight="1000"
                        android:textSize="20dp" />

                    <LinearLayout
                        android:layout_width="100dp"
                        android:layout_height="25dp"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="match_parent"
                            android:src="@drawable/user"
                            android:textAlignment="center"
                            app:tint="#c3c3c3" />

                        <TextView
                            android:layout_width="75dp"
                            android:layout_height="25dp"
                            android:fontFamily="@font/inter"
                            android:padding="5dp"
                            android:paddingVertical="15dp"
                            android:text="creator"
                            android:textAlignment="textStart"
                            android:textColor="#c3c3c3"
                            android:textFontWeight="600"
                            android:textSize="12dp" />
                    </LinearLayout>

                    <Button
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:backgroundTint="#268dd1"
                        android:fontFamily="@font/inter"
                        android:padding="1dp"
                        android:text="Start Game"
                        android:textSize="12.5dp"
                        app:cornerRadius="10dp" />
                </LinearLayout>
            </LinearLayout>

